			"defaultValue": "naiyar-adf"
		},
		"DS_Datalake_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'DS_Datalake'"
		},
		"DS_Datalake_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://naiyarstorage.dfs.core.windows.net/"
